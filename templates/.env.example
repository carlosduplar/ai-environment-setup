# Required API keys and service credentials
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local

# ── Anthropic / Claude Code ──────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_AUTH_TOKEN=<YOUR_ANTHROPIC_API_KEY>

# If using a proxy (e.g. custom endpoint), set the base URL
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: override model names (useful with proxy services)
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-5
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5

# ── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=<YOUR_NVIDIA_API_KEY>

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>

# ── Mistral ──────────────────────────────────────────────────────────────────
# Get from: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=<YOUR_MISTRAL_API_KEY>

# ── Google Cloud / Gemini / Firebase ─────────────────────────────────────────
# Project ID for gcloud / Firebase
GOOGLE_CLOUD_PROJECT=<YOUR_GCP_PROJECT_ID>

# Service account key path (if not using gcloud ADC)
# GOOGLE_APPLICATION_CREDENTIALS=<PATH_TO_SERVICE_ACCOUNT_JSON>

# Firebase CI token (for non-interactive CI environments)
# FIREBASE_TOKEN=<YOUR_FIREBASE_CI_TOKEN>

# ── GitHub ───────────────────────────────────────────────────────────────────
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=<YOUR_GITHUB_PAT>

# ── Bright Data MCP ──────────────────────────────────────────────────────────
# Get from: https://brightdata.com/
BRIGHT_DATA_API_TOKEN=<YOUR_BRIGHT_DATA_API_TOKEN>

# ── Atlassian CLI (acli) ─────────────────────────────────────────────────────
# ATLASSIAN_BASE_URL=<YOUR_JIRA_INSTANCE_URL>
# ATLASSIAN_API_TOKEN=<YOUR_ATLASSIAN_API_TOKEN>
# ATLASSIAN_USER_EMAIL=<YOUR_EMAIL>
