{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "../../hooks/pre-tool-use.sh",
        "powershell": "../../hooks/pre-tool-use.ps1",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "../../hooks/post-tool-use.sh",
        "powershell": "../../hooks/post-tool-use.ps1",
        "timeoutSec": 30
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "../../hooks/session-start.sh",
        "powershell": "../../hooks/session-start.ps1",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "../../hooks/session-end.sh",
        "powershell": "../../hooks/session-end.ps1",
        "timeoutSec": 30
      }
    ]
  }
}