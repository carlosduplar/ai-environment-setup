#!/usr/bin/env bash
# .bashrc.example — Git Bash profile template
# Copy to ~/.bashrc

# ── Source private env vars ───────────────────────────────────────────────────
if [[ -f "$HOME/.env.local" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$HOME/.env.local"
    set +a
fi

# ── Aliases ───────────────────────────────────────────────────────────────────
alias ll='ls -lah --color=auto'
alias g='git'
alias oc='opencode'

# ── PATH additions ─────────────────────────────────────────────────────────────
# uv tools
export PATH="$HOME/.local/bin:$PATH"

# gcloud
if [[ -f "$HOME/AppData/Local/Google/Cloud SDK/google-cloud-sdk/path.bash.inc" ]]; then
    source "$HOME/AppData/Local/Google/Cloud SDK/google-cloud-sdk/path.bash.inc"
    source "$HOME/AppData/Local/Google/Cloud SDK/google-cloud-sdk/completion.bash.inc"
fi

# ── Prompt ─────────────────────────────────────────────────────────────────────
PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
