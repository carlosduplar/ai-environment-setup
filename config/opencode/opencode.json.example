{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "write": "ask",
    "glob": "allow",
    "grep": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "task": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "del *": "deny",
      "Remove-Item *": "deny",
      "sudo *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git branch*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git remote*": "allow",
      "git config*": "allow",
      "git describe*": "allow",
      "git tag*": "allow",
      "git stash*": "allow",
      "git worktree*": "allow",
      "gh run view*": "allow",
      "gh run list*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "tree*": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "npm run typecheck*": "allow",
      "npm run build*": "allow",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "pnpm run lint*": "allow",
      "pnpm run typecheck*": "allow",
      "pnpm run build*": "allow",
      "yarn test*": "allow",
      "yarn lint*": "allow",
      "yarn typecheck*": "allow",
      "yarn build*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "ruff check*": "allow",
      "mypy *": "allow",
      "npm *": "ask",
      "pnpm *": "ask",
      "yarn *": "ask",
      "node *": "ask",
      "python *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "Get-ChildItem*": "allow",
      "gci*": "allow",
      "Select-String*": "allow",
      "Where-Object*": "allow",
      "ForEach-Object*": "allow",
      "Sort-Object*": "allow",
      "Measure-Object*": "allow",
      "Format-Table*": "allow",
      "Select-Object*": "allow",
      "Get-Content*": "allow",
      "Write-Output*": "allow",
      "Write-Host*": "allow",
      "Start-Sleep*": "allow",
      "Out-Null*": "allow",
      "2>`$null": "allow",
      "[System.IO.File]*": "allow",
      "[System.IO.Directory]*": "allow"
    }
  },
  "provider": {
    "github-copilot": { "options": { "timeout": 600000, "setCacheKey": true } },
    "mistral": { "options": { "timeout": 600000, "setCacheKey": true } },
    "openrouter": { "options": { "timeout": 600000, "setCacheKey": true } },
    "nvidia": { "options": { "timeout": 600000, "setCacheKey": true } },
    "google-vertex": { "options": { "timeout": 600000, "setCacheKey": true } }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  }
}
