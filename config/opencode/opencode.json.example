{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git branch --show-current*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "tree*": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "allow",
      "npm run typecheck*": "allow",
      "npm run build*": "allow",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "pnpm run lint*": "allow",
      "pnpm run typecheck*": "allow",
      "pnpm run build*": "allow",
      "yarn test*": "allow",
      "yarn lint*": "allow",
      "yarn typecheck*": "allow",
      "yarn build*": "allow",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "ruff check*": "allow",
      "mypy *": "allow",
      "npm *": "ask",
      "pnpm *": "ask",
      "yarn *": "ask",
      "node *": "ask",
      "python *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "rm *": "deny",
      "del *": "deny",
      "Remove-Item *": "deny",
      "sudo *": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "reasoningEffort": "high",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask",
        "websearch": "ask",
        "codesearch": "ask"
      }
    },
    "build": {
      "model": "opencode/mimo-v2-pro-free",
      "reasoningEffort": "high",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git rev-parse*": "allow",
          "git ls-files*": "allow",
          "git branch --show-current*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "ls*": "allow",
          "cat*": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "find *": "allow",
          "tree*": "allow",
          "npm test*": "allow",
          "npm run test*": "allow",
          "npm run lint*": "allow",
          "npm run typecheck*": "allow",
          "npm run build*": "allow",
          "pnpm test*": "allow",
          "pnpm run test*": "allow",
          "pnpm run lint*": "allow",
          "pnpm run typecheck*": "allow",
          "pnpm run build*": "allow",
          "yarn test*": "allow",
          "yarn lint*": "allow",
          "yarn typecheck*": "allow",
          "yarn build*": "allow",
          "pytest*": "allow",
          "python -m pytest*": "allow",
          "ruff check*": "allow",
          "mypy *": "allow",
          "rm *": "deny",
          "del *": "deny",
          "Remove-Item *": "deny",
          "sudo *": "deny"
        },
        "webfetch": "ask",
        "websearch": "ask",
        "codesearch": "ask"
      }
    }
  },
  "provider": {
    "github-copilot": { "options": { "timeout": 600000, "setCacheKey": true } },
    "mistral": { "options": { "timeout": 600000, "setCacheKey": true } },
    "openrouter": { "options": { "timeout": 600000, "setCacheKey": true } },
    "nvidia": { "options": { "timeout": 600000, "setCacheKey": true } },
    "google-vertex": { "options": { "timeout": 600000, "setCacheKey": true } }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  }
}
