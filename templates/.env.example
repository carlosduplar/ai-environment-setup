# Optional API keys and service credentials
# Copy this file to .env.local in the repo root and fill in values for services you use
# NEVER commit .env.local to git

# Note: Most AI services (Claude, GitHub Copilot) handle auth via their CLIs.
# This file is only needed for pure API-based services below.

# ── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Get from: https://build.nvidia.com/
# Required for: Using NVIDIA-hosted AI models
NVIDIA_API_KEY=<YOUR_NVIDIA_API_KEY>

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Get from: https://openrouter.ai/keys
# Required for: OpenRouter API access (multi-model gateway)
OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>

# ── Mistral ──────────────────────────────────────────────────────────────────
# Get from: https://console.mistral.ai/api-keys/
# Required for: Mistral AI API access
MISTRAL_API_KEY=<YOUR_MISTRAL_API_KEY>

# ── Google Cloud / Gemini / Firebase ────────────────────────────────────────
# Project ID for gcloud / Firebase
# Required for: GCP services, Gemini API, Firebase CLI
GOOGLE_CLOUD_PROJECT=<YOUR_GCP_PROJECT_ID>

# Service account key path (if not using gcloud ADC)
# GOOGLE_APPLICATION_CREDENTIALS=<PATH_TO_SERVICE_ACCOUNT_JSON>

# Firebase CI token (for non-interactive CI environments)
# FIREBASE_TOKEN=<YOUR_FIREBASE_CI_TOKEN>

# ── Bright Data CLI ──────────────────────────────────────────────────────────
# Get from: https://brightdata.com/cp/setting
# Required for: Bright Data CLI and web scraping skills
BRIGHTDATA_API_KEY=<YOUR_BRIGHTDATA_API_KEY>


