{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  // Apply via: cp config/claude-code/settings.json.example ~/.claude/settings.json
  // Then edit to substitute $ENV_VAR placeholders with actual values from .env.local
  "env": {
    // ── Model routing ──────────────────────────────────────────────────────
    // Default: use Anthropic directly. Set ANTHROPIC_BASE_URL to proxy if needed.
    "ANTHROPIC_AUTH_TOKEN": "$ANTHROPIC_AUTH_TOKEN",
    // "ANTHROPIC_BASE_URL": "https://api.anthropic.com",

    // Telemetry opt-out
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "true",
    "DISABLE_ERROR_REPORTING": "true",
    "DISABLE_TELEMETRY": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log*)"
    ],
    "deny": [
      "Read(*.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(git push *)",
      "Bash(pip install*)",
      "Bash(uv pip install*)"
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
