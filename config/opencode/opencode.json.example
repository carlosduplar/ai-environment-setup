{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "bash": {
      "*": "ask",
      "rm *": "deny",
      "del *": "deny",
      "Remove-Item *": "deny",
      "sudo *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "git branch*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git remote*": "allow",
      "git config*": "allow",
      "git describe*": "allow",
      "git tag*": "allow",
      "git stash*": "allow",
      "git worktree*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git push*": "ask",
      "rg *": "allow",
      "grep *": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "tree*": "allow",
      "echo *": "allow",
      "dir *": "allow",
      "findstr *": "allow",
      "printf *": "allow",
      "npm test*": "allow",
      "npm run test*": "allow",
      "npm run lint*": "ask",
      "npm run typecheck*": "allow",
      "npm run build*": "ask",
      "pnpm test*": "allow",
      "pnpm run test*": "allow",
      "pnpm run lint*": "ask",
      "pnpm run typecheck*": "allow",
      "pnpm run build*": "ask",
      "yarn test*": "allow",
      "yarn lint*": "ask",
      "yarn typecheck*": "allow",
      "yarn build*": "ask",
      "pytest*": "allow",
      "python -m pytest*": "allow",
      "ruff check*": "allow",
      "mypy *": "allow",
      "npm *": "ask",
      "pnpm *": "ask",
      "yarn *": "ask",
      "node *": "ask",
      "python *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "Get-ChildItem*": "allow",
      "gci*": "allow",
      "Test-Path*": "allow",
      "Get-Command*": "allow",
      "Select-String*": "allow",
      "Where-Object*": "allow",
      "ForEach-Object*": "allow",
      "Sort-Object*": "allow",
      "Measure-Object*": "allow",
      "Format-Table*": "allow",
      "Select-Object*": "allow",
      "Get-Content*": "allow",
      "Write-Output*": "allow",
      "Write-Host*": "allow",
      "Start-Sleep*": "allow",
      "Out-Null*": "allow",
      "2>`$null": "allow",
      "[System.IO.File]*": "allow",
      "[System.IO.Directory]*": "allow",
      "ctx7*": "allow",
      "playwright*": "allow",
      "markitdown*": "allow",
      "jq*": "allow",
      "winget list*": "allow",
      "winget search*": "allow",
      "winget show*": "allow",
      "node --version*": "allow",
      "node -v*": "allow",
      "npm list*": "allow",
      "npm view*": "allow",
      "npx --version*": "allow",
      "npx ctx7@latest*": "allow",
      "python --version*": "allow",
      "python -V*": "allow",
      "pip list*": "allow",
      "pip show*": "allow",
      "pip install*": "ask",
      "uv pip install*": "ask",
      "gh repo view*": "allow",
      "gh repo list*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh gist list*": "allow",
      "gh gist view*": "allow",
      "gh api*": "ask",
      "gh auth status*": "allow",
      "gh config*": "allow",
      "gh variable list*": "allow",
      "gh secret list*": "allow",
      "gh cache list*": "allow",
      "gh codespace list*": "allow",
      "gh codespace logs*": "allow",
      "gh extension list*": "allow",
      "gh label list*": "allow",
      "gh milestone list*": "allow",
      "gh project list*": "allow",
      "gh ssh-key list*": "allow",
      "gh gpg-key list*": "allow",
      "gh alias list*": "allow",
      "firebase projects:list*": "allow",
      "firebase apps:list*": "allow",
      "firebase hosting:channel:list*": "allow",
      "firebase functions:list*": "allow",
      "firebase --version*": "allow",
      "firebase help*": "allow",
      "gws*": "allow"
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.2,
      "reasoningEffort": "high",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask",
        "websearch": "ask"
      }
    },
    "auto": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "temperature": 0.3,
      "reasoningEffort": "high",
      "permission": {
        "edit": "allow",
        "webfetch": "ask"
      }
    },
    "build": {
      "model": "opencode/mimo-v2-pro-free",
      "temperature": 0.3,
      "reasoningEffort": "high",
      "permission": {
        "edit": "ask",
        "webfetch": "ask"
      }
    }
  },
  "provider": {
    "github-copilot": { "options": { "timeout": 600000, "setCacheKey": true } },
    "mistral": { "options": { "timeout": 600000, "setCacheKey": true } },
    "openrouter": { "options": { "timeout": 600000, "setCacheKey": true } },
    "nvidia": { "options": { "timeout": 600000, "setCacheKey": true } },
    "google-vertex": { "options": { "timeout": 600000, "setCacheKey": true } }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  }
}
