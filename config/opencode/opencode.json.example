{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git rev-parse*": "allow",
      "git ls-files*": "allow",
      "rg *": "allow",
      "grep *": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "npm *": "ask",
      "pnpm *": "ask",
      "node *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "rm *": "deny",
      "sudo *": "deny"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "codesearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "reasoningEffort": "high",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask",
        "websearch": "ask",
        "codesearch": "ask"
      }
    },
    "build": {
      "model": "opencode/mimo-v2-pro-free",
      "reasoningEffort": "high",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "rm *": "deny",
          "sudo *": "deny"
        },
        "webfetch": "ask",
        "websearch": "ask",
        "codesearch": "ask"
      }
    }
  },
  "provider": {
    "github-copilot": { "options": { "timeout": 600000, "setCacheKey": true } },
    "mistral": { "options": { "timeout": 600000, "setCacheKey": true } },
    "openrouter": { "options": { "timeout": 600000, "setCacheKey": true } },
    "nvidia": { "options": { "timeout": 600000, "setCacheKey": true } },
    "google-vertex": { "options": { "timeout": 600000, "setCacheKey": true } }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  }
}
