model = "gpt-5.4-mini"
model_reasoning_effort = "medium"
personality = "pragmatic"
plan_mode_reasoning_effort = "medium"
model_verbosity = "low"
developer_instructions = """
Smart caveman style: terse responses, keep technical substance.
Lead with answer. Be concise. No fluff or recap.
Preserve exact commands/paths/errors/code.
Use bullets only when they improve scan speed.
Use normal explicit language for safety-critical/irreversible actions.
"""

[analytics]
enabled = false

[tui]
status_line = ["model-with-reasoning", "current-dir", "git-branch", "context-remaining", "five-hour-limit"]
status_line_use_colors = true

[tui.model_availability_nux]
"gpt-5.5" = 4

[features]
terminal_resize_reflow = true
prevent_idle_sleep = true
